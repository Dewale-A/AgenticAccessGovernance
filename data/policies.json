  "sod_rules": [
    {
      "id": "SOD001",
      "name": "Trade Execution and Settlement Segregation",
      "description": "Users cannot have both trade execution and settlement access to prevent fraud",
      "conflicting_systems": ["SYS004", "SYS009"],
      "severity": "HIGH",
      "exceptions_allowed": false
    },
    {
      "id": "SOD002",
      "name": "Model Development and Validation Segregation",
      "description": "Model developers cannot validate their own models",
      "conflicting_systems": ["SYS002", "SYS010"],
      "conflicting_roles": ["risk_analyst"],
      "severity": "HIGH",
      "exceptions_allowed": false
    },
    {
      "id": "SOD003",
      "name": "Access Administration and Audit Review Segregation",
      "description": "Access administrators cannot review their own access decisions",
      "conflicting_systems": ["SYS007", "SYS011"],
      "severity": "HIGH",
      "exceptions_allowed": false
    },
    {
      "id": "SOD004",
      "name": "Data Entry and Approval Segregation",
      "description": "Users cannot both enter and approve the same financial data",
      "conflicting_systems": ["SYS001", "SYS012"],
      "conflicting_roles": ["teller", "customer_advisor"],
      "severity": "MEDIUM",
      "exceptions_allowed": true,
      "exception_conditions": ["manager_approval", "dual_control"]
    },
    {
      "id": "SOD005",
      "name": "Customer Account Management and Credit Approval",
      "description": "Customer-facing staff cannot approve their own credit decisions",
      "conflicting_systems": ["SYS001", "SYS002"],
      "conflicting_roles": ["customer_advisor", "branch_manager"],
      "severity": "MEDIUM",
      "exceptions_allowed": true,
      "exception_conditions": ["senior_manager_approval"]
    }
  ],
  "regulatory_constraints": [
    {
      "id": "REG001",
      "regulator": "PIPEDA",
      "regulation_name": "Personal Information Protection and Electronic Documents Act",
      "description": "Privacy training required for PII access",
      "applies_to_systems": ["SYS003", "SYS007"],
      "certification_required": "privacy_training",
      "certification_validity_days": 365,
      "is_mandatory": true,
      "violation_severity": "HIGH"
    },
    {
      "id": "REG002",
      "regulator": "SR 11-7",
      "regulation_name": "Supervisory Guidance on Model Risk Management",
      "description": "Model risk training required for model access",
      "applies_to_systems": ["SYS002", "SYS006", "SYS010"],
      "certification_required": "model_risk_training",
      "certification_validity_days": 365,
      "is_mandatory": true,
      "violation_severity": "HIGH"
    },
    {
      "id": "REG003",
      "regulator": "OSFI",
      "regulation_name": "OSFI Guideline B-13",
      "description": "Background check required for core banking access",
      "applies_to_systems": ["SYS001", "SYS005", "SYS011"],
      "certification_required": "background_check",
      "certification_validity_days": 1095,
      "is_mandatory": true,
      "violation_severity": "HIGH"
    },
    {
      "id": "REG004",
      "regulator": "SOX",
      "regulation_name": "Sarbanes-Oxley Act",
      "description": "Annual certification required for financial reporting access",
      "applies_to_systems": ["SYS004", "SYS009", "SYS012"],
      "certification_required": "sox_certification",
      "certification_validity_days": 365,
      "is_mandatory": true,
      "violation_severity": "HIGH"
    },
    {
      "id": "REG005",
      "regulator": "IIROC",
      "regulation_name": "Investment Industry Regulatory Organization",
      "description": "Trading certification required for market access",
      "applies_to_systems": ["SYS004", "SYS009"],
      "applies_to_roles": ["trader", "treasury_analyst", "treasury_vp"],
      "certification_required": "trading_certification",
      "certification_validity_days": 730,
      "is_mandatory": true,
      "violation_severity": "HIGH"
    }
