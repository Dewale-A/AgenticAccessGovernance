  "sensitivity_rules": [
    {
      "id": "SENS001",
      "sensitivity_tier": "Restricted",
      "allowed_roles": ["branch_manager", "risk_manager", "risk_vp", "compliance_director", "ciso", "treasury_vp"],
      "conditions": {
        "background_check_required": true,
        "manager_approval_required": true
      }
    },
    {
      "id": "SENS002",
      "sensitivity_tier": "Confidential",
      "allowed_roles": ["risk_analyst", "risk_manager", "risk_vp", "compliance_officer", "compliance_analyst", "database_admin", "system_admin"],
      "conditions": {
        "training_certification_required": true
      }
    },
    {
      "id": "SENS003",
      "sensitivity_tier": "Internal",
      "allowed_roles": ["all_employees"],
      "conditions": {}
    }
